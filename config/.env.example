# CareerClaw Environment Variables
# Copy this file to the project root as .env and fill in your values.
# See SETUP.md for detailed instructions on obtaining each key.

# ─── OpenClaw (optional — only needed for OC agent scripts) ─────────
# OPENCLAW_CONFIG_PATH=/path/to/your/openclaw.careerclaw.json
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# ─── LLM API Keys ──────────────────────────────────────────────────
# At least ONE of these is required for cover letter generation.
# Gemini is recommended (free tier available).
GEMINI_API_KEY=your-gemini-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Supabase (required) ──────────────────────────────────────────
# Create a free Supabase project at https://supabase.com
# Run the migrations in supabase/migrations/ to set up the schema.
JOBCLAW_SUPABASE_URL=https://your-project-id.supabase.co
JOBCLAW_SUPABASE_KEY=your-service-role-key

# ─── Gmail IMAP (optional — needed for Greenhouse email verification) ─
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
# Use the same email address you apply with.
GMAIL_USER=your-apply-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ─── Rate Limits (optional, sensible defaults provided) ────────────
MAX_APPLICATIONS_PER_DAY=25
MAX_APPLICATIONS_PER_HOUR=5
MAX_OUTREACH_EMAILS_PER_DAY=20
MAX_SEARCHES_PER_HOUR=20
